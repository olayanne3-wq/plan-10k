{
  "version": 2,
  "builds": [
    { "src": "public/**", "use": "@vercel/static" },
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/strava/(.*)", "dest": "/api/strava.js" },
    { "src": "/api/coach", "dest": "/api/coach.js" },
    { "src": "/sw.js", "dest": "/public/sw.js" },
    { "src": "/manifest.json", "dest": "/public/manifest.json" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
